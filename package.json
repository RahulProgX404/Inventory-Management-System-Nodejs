{
  "name": "inventory-management-system-backend",
  "version": "1.0.0",
  "description": "Professional Node.js starter kit",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "start:prod": "node src/index.js",
    "build": "esbuild src/index.js --bundle --platform=node --format=esm --outdir=dist --external:express --external:winston --external:morgan --external:jsonwebtoken --external:zod --external:helmet --external:cors --external:compression --external:express-rate-limit --external:http-status-codes --external:cookie-parser --external:bcryptjs --external:dotenv --external:mailtrap",
    "preview": "node dist/index.js",
    "lint": "eslint src --fix",
    "format": "prettier --write src",
    "clean": "rm -rf dist logs *.log"
  },
  "keywords": [
    "node",
    "express",
    "starter",
    "kit"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "crypto": "^1.0.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "http-status-codes": "^2.3.0",
    "jsonwebtoken": "^9.0.3",
    "mailtrap": "^4.6.0",
    "mongoose": "^9.7.0",
    "morgan": "^1.10.0",
    "winston": "^3.8.2",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "esbuild": "^0.19.0",
    "eslint": "^8.55.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.1.1"
  }
}
